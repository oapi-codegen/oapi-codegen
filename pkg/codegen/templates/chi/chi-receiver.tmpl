type {{.Prefix}}ReceiverInterface interface {
{{range .Operations -}}
{{.SummaryAsComment}}
// Handle{{.OperationId}}{{$.Prefix}} handles the {{.Method}} {{$.PrefixLower}} for {{.SourceName}}.
Handle{{.OperationId}}{{$.Prefix}}(w http.ResponseWriter, r *http.Request{{if .RequiresParamObject}}, params {{.OperationId}}Params{{end}})
{{end}}
