{{- if and (gt (len .SecuritySchemeProviders) 0) opts.Compatibility.EnableAuthScopesOnContext }}
const (
{{range $Provider := .SecuritySchemeProviders}}
    {{- if $Provider.ImportedScopes}}
    {{- $Provider.Name | sanitizeGoIdentity | ucFirst}}Scopes = {{$Provider.ImportedScopes}}
    {{- else}}
    {{- $Provider.Name | sanitizeGoIdentity | ucFirst}}Scopes {{$Provider.Name | schemaNameToTypeName | lcFirst}}ContextKey = "{{$Provider.Name}}.Scopes"
    {{- end}}
{{end}}
)
{{end}}
{{range $Enum := .EnumDefinitions}}
// Defines values for {{$Enum.TypeName}}.
const (
{{range $name, $value := $Enum.GetValues}}
  {{$name}} {{$Enum.TypeName}} = {{if $Enum.ValueWrapper}}{{$value | toGoString}}{{else}}{{$value}}{{end -}}
{{end}}
)
{{if not $.SkipEnumValidate}}
// Valid indicates whether the value is a known member of the {{$Enum.TypeName}} enum.
func (e {{$Enum.TypeName}}) Valid() bool {
    switch e {
    {{range $name, $value := $Enum.GetValues}}case {{$name}}:
        return true
    {{end}}default:
        return false
    }
}
{{end}}
{{end}}
